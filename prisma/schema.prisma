generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────

enum Sex {
  male
  female
  other
}

enum Goal {
  lose
  maintain
  gain
}

enum ActivityLevel {
  sedentary
  light
  moderate
  active
  veryActive
}

enum PlanStatus {
  draft
  active
  completed
}

enum MealType {
  breakfast
  mid_morning    // almuerzo/merienda
  lunch
  dinner
  snack
}

enum DietType {
  omnivore
  vegetarian
  vegan
  pescatarian
}

enum EatingOutFrequency {
  never
  rarely
  sometimes
  often
}

enum MealComplexity {
  simple
  moderate
  advanced
}

enum ShoppingListStatus {
  draft
  reviewed
  purchased
}

enum ConfidenceLevel {
  high
  medium
  low
}

enum VarietyLevel {
  low
  medium
  high
}

enum ConversationStep {
  PROFILE_REVIEW
  PROFILE_MODIFICATION
  PREFERENCES_COLLECTION
  GENERATION
  REVIEW_MODIFICATION
  CONFIRMATION
}

enum FoodGroup {
  carbohydrates
  protein
  fat
  other
}

// ─── Entities ────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile           Profile?
  conversationState ConversationState?
  mealPlans          MealPlan[]
  mealLogs           MealLog[]
  weightLogs         WeightLog[]
  shoppingLists      ShoppingList[]
  progressSnapshots  ProgressSnapshot[]
}

model Profile {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight          Float         // kg
  height          Float         // cm
  age             Int
  sex             Sex
  goal            Goal
  activityLevel   ActivityLevel
  targetCalories  Int?
  targetProtein   Float?
  targetCarbs     Float?
  targetFat       Float?
  allergies          String[]          @default([])
  forbiddenFoods     String[]          @default([])
  dietType           DietType?
  cookingTimeAvailable Int?
  eatingOutFrequency EatingOutFrequency?
  includeSnacks      Boolean           @default(false)
  mealComplexity     MealComplexity?
  mealsPerDay        Int               @default(3)
  varietyPreference  VarietyLevel?
  budgetFriendly     Boolean           @default(false)
  weeklyBudget       Float?
  trainingRoutine    String?
  favoriteFoods      String[]          @default([])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model MealPlan {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId    String?
  template      MealPlanTemplate? @relation(fields: [templateId], references: [id])
  startDate     DateTime
  endDate       DateTime
  status        PlanStatus @default(draft)
  totalCalories Float?
  meals         Meal[]
  shoppingLists ShoppingList[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([userId, startDate])
  @@index([userId, status])
}

model Meal {
  id              String   @id @default(cuid())
  mealPlanId      String
  mealPlan        MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  dayOfWeek       Int      // 0=Monday, 6=Sunday
  mealType        MealType
  name            String
  description     String
  calories        Float
  protein         Float
  carbs           Float
  fat             Float
  selectedOptions Json?    // [{foodOptionId, quantity, notes}]
}

model MealLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  mealType         MealType
  rawInput         String
  interpretedFoods Json     // [{foodName, quantity, unit, calories, protein, carbs, fat, confidence}]
  totalCalories    Float?
  createdAt        DateTime @default(now())

  @@index([userId, date])
}

model Food {
  id       String  @id @default(cuid())
  name     String
  category String?
  unit     String  @default("g")
  calories Float   // per 100g
  protein  Float
  carbs    Float
  fat      Float
  brand    String?

  @@unique([name, brand])
  @@index([name])
}

// ─── Meal Plan Templates (Carla Bozal style) ─────────────────────────────

model MealPlanTemplate {
  id          String   @id @default(cuid())
  name        String   // e.g., "Carla Bozal - 3+ snacks"
  description String?
  objective   String?  // e.g., "reducir la inflamación"
  guidelines  String[] @default([])
  meals       MealTemplate[]
  recipes     Recipe[]
  mealPlans   MealPlan[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MealTemplate {
  id         String           @id @default(cuid())
  templateId String
  template   MealPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  mealType   MealType
  order      Int              // 1, 2, 3, 4
  name       String           // e.g., "Desayuno", "Almuerzo"
  groups     MealTemplateGroup[]
}

model MealTemplateGroup {
  id             String       @id @default(cuid())
  mealTemplateId String
  mealTemplate   MealTemplate @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  foodGroup      FoodGroup
  options        FoodOption[]
}

model FoodOption {
  id              String            @id @default(cuid())
  mealTemplateGroupId String
  mealTemplateGroup MealTemplateGroup @relation(fields: [mealTemplateGroupId], references: [id], onDelete: Cascade)
  name            String            // e.g., "pan integral o centeno"
  quantity        Float             // e.g., 60
  unit            String            // e.g., "gr"
  notes           String?           // e.g., "*" means no extra fats needed
  calories        Float?
  protein         Float?
  carbs           Float?
  fat             Float?
}

model Recipe {
  id          String   @id @default(cuid())
  templateId  String
  template    MealPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name        String
  description String?
  ingredients String[] @default([])
  steps       String[] @default([])
  mealType    MealType?
}

// ─── Conversation State (Nutritionist Wizard) ────────────────────────────

model ConversationState {
  id            String           @id @default(cuid())
  userId        String           @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStep   ConversationStep @default(PROFILE_REVIEW)
  profileData   Json?
  preferences   Json?
  generatedPlan Json?
  modifications Json?
  validatedJson Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// ─── Weight Tracking ─────────────────────────────────────────────────────

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float    // kg
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Shopping Lists ──────────────────────────────────────────────────────

model ShoppingList {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlanId    String?
  mealPlan      MealPlan?         @relation(fields: [mealPlanId], references: [id])
  budget        Float?
  totalEstimate Float?
  status        ShoppingListStatus @default(draft)
  imageUrl      String?
  items         ShoppingItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, status])
}

model ShoppingItem {
  id             String   @id @default(cuid())
  shoppingListId String
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  name           String
  quantity       String?
  price          Float?
  confidence     ConfidenceLevel @default(medium)
  checked        Boolean  @default(false)
  matchedToPlan  Boolean  @default(false)
  category       String?
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([shoppingListId])
}

// ─── Progress Snapshots ──────────────────────────────────────────────────

model ProgressSnapshot {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  totalCalories  Float?
  totalProtein   Float?
  totalCarbs     Float?
  totalFat       Float?
  adherenceScore Float?   // 0-100
  mealsLogged    Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}
