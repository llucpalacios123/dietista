generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────

enum Sex {
  male
  female
  other
}

enum Goal {
  lose
  maintain
  gain
}

enum ActivityLevel {
  sedentary
  light
  moderate
  active
  veryActive
}

enum PlanStatus {
  draft
  active
  completed
}

enum MealType {
  breakfast
  mid_morning    // almuerzo/merienda
  lunch
  dinner
  snack
}

enum DietType {
  omnivore
  vegetarian
  vegan
  pescatarian
}

enum EatingOutFrequency {
  never
  rarely
  sometimes
  often
}

enum MealComplexity {
  simple
  moderate
  advanced
}

enum ShoppingListStatus {
  draft
  reviewed
  purchased
}

enum ConfidenceLevel {
  high
  medium
  low
}

enum VarietyLevel {
  low
  medium
  high
}

enum ConversationStep {
  PROFILE_REVIEW
  PROFILE_MODIFICATION
  PREFERENCES_COLLECTION
  GENERATION
  REVIEW_MODIFICATION
  CONFIRMATION
}

enum FoodGroup {
  carbohydrates
  protein
  fat
  other
}

enum MuscleGroup {
  legs
  back
  chest
  shoulders
  arms
  core
  cardio
}

enum WorkoutGoal {
  strength
  endurance
  weight_loss
  toning
  hypertrophy
}

enum FitnessLevel {
  beginner
  intermediate
  advanced
}

// ─── Entities ────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile           Profile?
  conversationState ConversationState?
  mealPlans          MealPlan[]
  mealLogs           MealLog[]
  weightLogs         WeightLog[]
  shoppingLists      ShoppingList[]
  progressSnapshots  ProgressSnapshot[]
  workoutSessions    WorkoutSession[]
  diaryEntries       DiaryEntry[]
  workoutPlans       WorkoutPlan[]
}

model Profile {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight          Float         // kg
  height          Float         // cm
  age             Int
  sex             Sex
  goal            Goal
  activityLevel   ActivityLevel
  targetCalories  Int?
  targetProtein   Float?
  targetCarbs     Float?
  targetFat       Float?
  allergies          String[]          @default([])
  forbiddenFoods     String[]          @default([])
  dietType           DietType?
  cookingTimeAvailable Int?
  eatingOutFrequency EatingOutFrequency?
  includeSnacks      Boolean           @default(false)
  mealComplexity     MealComplexity?
  mealsPerDay        Int               @default(3)
  varietyPreference  VarietyLevel?
  budgetFriendly     Boolean           @default(false)
  weeklyBudget       Float?
  trainingRoutine    String?
  favoriteFoods      String[]          @default([])
  locale             String            @default("es")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model MealPlan {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId    String?
  template      MealPlanTemplate? @relation(fields: [templateId], references: [id])
  startDate     DateTime
  endDate       DateTime
  status        PlanStatus @default(draft)
  totalCalories Float?
  name          String?
  meals         Meal[]
  shoppingLists ShoppingList[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // ── Plan-level preference overrides (nullable = "use profile value") ──
  dietType             DietType?
  allergies            String[]          @default([])
  forbiddenFoods       String[]          @default([])
  mealComplexity       MealComplexity?
  cookingTimeAvailable Int?
  mealsPerDay          Int?
  includeSnacks        Boolean?
  varietyPreference    VarietyLevel?
  favoriteFoods        String[]          @default([])
  budgetFriendly       Boolean?
  weeklyBudget         Float?
  eatingOutFrequency   EatingOutFrequency?

  @@unique([userId, startDate])
  @@index([userId, status])
}

model Meal {
  id              String   @id @default(cuid())
  mealPlanId      String
  mealPlan        MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  dayOfWeek       Int      // 0=Monday, 6=Sunday
  mealType        MealType
  name            String
  description     String
  calories        Float
  protein         Float
  carbs           Float
  fat             Float
  selectedOptions Json?    // [{foodOptionId, quantity, notes}]
  translations    Json?
  ingredients     Json    @default("[]") // [{name, quantity?, unit?}]
  instructions    String?
}

model MealLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  mealType         MealType
  rawInput         String
  interpretedFoods Json     // [{foodName, quantity, unit, calories, protein, carbs, fat, confidence}]
  totalCalories    Float?
  createdAt        DateTime @default(now())

  @@index([userId, date])
}

model Food {
  id       String  @id @default(cuid())
  name     String
  category String?
  unit     String  @default("g")
  calories Float   // per 100g
  protein  Float
  carbs    Float
  fat      Float
  brand    String?

  @@unique([name, brand])
  @@index([name])
}

// ─── Meal Plan Templates (Carla Bozal style) ─────────────────────────────

model MealPlanTemplate {
  id          String   @id @default(cuid())
  name        String   // e.g., "Carla Bozal - 3+ snacks"
  description String?
  objective   String?  // e.g., "reducir la inflamación"
  guidelines  String[] @default([])
  meals       MealTemplate[]
  recipes     Recipe[]
  mealPlans   MealPlan[]
  translations Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MealTemplate {
  id         String           @id @default(cuid())
  templateId String
  template   MealPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  mealType   MealType
  order      Int              // 1, 2, 3, 4
  name       String           // e.g., "Desayuno", "Almuerzo"
  groups     MealTemplateGroup[]
  translations Json?
}

model MealTemplateGroup {
  id             String       @id @default(cuid())
  mealTemplateId String
  mealTemplate   MealTemplate @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  foodGroup      FoodGroup
  options        FoodOption[]
}

model FoodOption {
  id              String            @id @default(cuid())
  mealTemplateGroupId String
  mealTemplateGroup MealTemplateGroup @relation(fields: [mealTemplateGroupId], references: [id], onDelete: Cascade)
  name            String            // e.g., "pan integral o centeno"
  quantity        Float             // e.g., 60
  unit            String            // e.g., "gr"
  notes           String?           // e.g., "*" means no extra fats needed
  calories        Float?
  protein         Float?
  carbs           Float?
  fat             Float?
  translations    Json?
}

model Recipe {
  id          String   @id @default(cuid())
  templateId  String
  template    MealPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name        String
  description String?
  ingredients String[] @default([])
  steps       String[] @default([])
  mealType    MealType?
  translations Json?
}

// ─── Conversation State (Nutritionist Wizard) ────────────────────────────

model ConversationState {
  id            String           @id @default(cuid())
  userId        String           @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStep   ConversationStep @default(PROFILE_REVIEW)
  profileData   Json?
  preferences   Json?
  generatedPlan Json?
  modifications Json?
  validatedJson Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// ─── Weight Tracking ─────────────────────────────────────────────────────

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float    // kg
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Shopping Lists ──────────────────────────────────────────────────────

model ShoppingList {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlanId    String?
  mealPlan      MealPlan?         @relation(fields: [mealPlanId], references: [id])
  budget        Float?
  totalEstimate Float?
  status        ShoppingListStatus @default(draft)
  imageUrl      String?
  items         ShoppingItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, status])
}

model ShoppingItem {
  id             String   @id @default(cuid())
  shoppingListId String
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  name           String
  quantity       String?
  price          Float?
  confidence     ConfidenceLevel @default(medium)
  checked        Boolean  @default(false)
  matchedToPlan  Boolean  @default(false)
  category       String?
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([shoppingListId])
}

// ─── Workout Tracking ────────────────────────────────────────────────────

model WorkoutSession {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime     @default(now())
  notes     String?
  sets      WorkoutSet[]
  createdAt DateTime     @default(now())

  @@index([userId, date])
}

model WorkoutSet {
  id              String         @id @default(cuid())
  sessionId       String
  session         WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseName    String
  muscleGroup     MuscleGroup
  setNumber       Int
  reps            Int?
  plannedReps     Int?
  plannedWeightKg Float?
  weightKg        Float?
  notes           String?
  createdAt       DateTime       @default(now())

  @@index([sessionId])
}

// ─── Diary Entries ────────────────────────────────────────────────────────────

model DiaryEntry {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  mealType       MealType
  mealId         String?
  completed      Boolean  @default(false)
  actualCalories Float?
  actualProtein  Float?
  actualCarbs    Float?
  actualFat      Float?
  aiSuggestion   Json?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date, mealType])
  @@index([userId, date])
}

// ─── Workout Plans ────────────────────────────────────────────────────────

model WorkoutPlan {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  goal        WorkoutGoal
  level       FitnessLevel
  daysPerWeek Int          // 1..7
  status      PlanStatus   @default(draft)
  content     Json         // WorkoutPlanContent (Zod-validated)
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, status])
}

// ─── Progress Snapshots ──────────────────────────────────────────────────

model ProgressSnapshot {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  totalCalories  Float?
  totalProtein   Float?
  totalCarbs     Float?
  totalFat       Float?
  adherenceScore Float?   // 0-100
  mealsLogged    Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}
